/// Parallel iterator methods and other parallel methods.
/// 
/// The following methods **require crate feature `"rayon"`**.
/// 
/// See also the `IntoParallelIterator` implementations.
impl<T, S> IndexSet<T, S> where T: Hash + Eq + Sync, S: BuildHasher + Sync {
 pub fn par_difference(&self, other: &IndexSet<T, S2>) -> ParDifference<'a, T, S, S2> {
 ParDifference { set1: self, set2: other }
 }
 
 pub fn par_symmetric_difference(&self, other: &IndexSet<T, S2>) -> ParSymmetricDifference<'a, T, S, S2> {
 ParSymmetricDifference { set1: self, set2: other }
 }
 
 pub fn par_intersection(&self, other: &IndexSet<T, S2>) -> ParIntersection<'a, T, S, S2> {
 ParIntersection { set1: self, set2: other }
 }
 
 pub fn par_union(&self, other: &IndexSet<T, S2>) -> ParUnion<'a, T, S, S2> {
 ParUnion { set1: self, set2: other }
 }
 
 pub fn par_eq(&self, other: &IndexSet<T, S2>) -> bool {
 self.len() == other.len() &&self.par_is_subset(other)
 }
 
 pub fn par_is_disjoint(&self, other: &IndexSet<T, S2>) -> bool {
 if self.len() <= other.len() { self.par_iter().all(move | value | ! other.contains(value)) } else { other.par_iter().all(move | value | ! self.contains(value)) }
 }
 
 pub fn par_is_superset(&self, other: &IndexSet<T, S2>) -> bool {
 other.par_is_subset(self)
 }
 
 pub fn par_is_subset(&self, other: &IndexSet<T, S2>) -> bool {
 self.len() <= other.len() &&self.par_iter().all(move | value | other.contains(value))
 }
 
}

