/// Parallel sorting methods.
/// 
/// The following methods **require crate feature `"rayon"`**.
impl<T, S> IndexSet<T, S> where T: Send {
 pub fn par_sort(&mut self) {
 self.with_entries(| entries | { entries.par_sort_by(| a, b | T::cmp(&a.key, &b.key)); });
 }
 
 pub fn par_sort_by(&mut self, cmp: F) {
 self.with_entries(| entries | { entries.par_sort_by(move | a, b | cmp(&a.key, &b.key)); });
 }
 
 pub fn par_sorted_by(self, cmp: F) -> IntoParIter<T> {
 let mut entries = self.into_entries();
 entries.par_sort_by(move | a, b | cmp(&a.key, &b.key));
 IntoParIter { entries }
 }
 
 pub fn par_sort_by_key(&mut self, sort_key: F) {
 self.with_entries(move | entries | { entries.par_sort_by_key(move | a | sort_key(&a.key)); });
 }
 
 pub fn par_sort_unstable(&mut self) {
 self.with_entries(| entries | { entries.par_sort_unstable_by(| a, b | T::cmp(&a.key, &b.key)); });
 }
 
 pub fn par_sort_unstable_by(&mut self, cmp: F) {
 self.with_entries(| entries | { entries.par_sort_unstable_by(move | a, b | cmp(&a.key, &b.key)); });
 }
 
 pub fn par_sorted_unstable_by(self, cmp: F) -> IntoParIter<T> {
 let mut entries = self.into_entries();
 entries.par_sort_unstable_by(move | a, b | cmp(&a.key, &b.key));
 IntoParIter { entries }
 }
 
 pub fn par_sort_unstable_by_key(&mut self, sort_key: F) {
 self.with_entries(move | entries | { entries.par_sort_unstable_by_key(move | a | sort_key(&a.key)); });
 }
 
 pub fn par_sort_by_cached_key(&mut self, sort_key: F) {
 self.with_entries(move | entries | { entries.par_sort_by_cached_key(move | a | sort_key(&a.key)); });
 }
 
}

impl<T, S> FromParallelIterator<T> for IndexSet<T, S> where T: Eq + Hash + Send, S: BuildHasher + Default + Send {
 fn from_par_iter(iter: I) -> Self {
 let list = collect(iter);
 let len = list.iter().map(Vec::len).sum();
 let mut set = Self::with_capacity_and_hasher(len, S::default());
 for vec in list { set.extend(vec); }
 set
 }
 
}

impl<T, S> ParallelExtend<T> for IndexSet<T, S> where T: Eq + Hash + Send, S: BuildHasher + Send {
 fn par_extend(&mut self, iter: I) {
 for vec in collect(iter) { self.extend(vec); }
 }
 
}

